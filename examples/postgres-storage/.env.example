# Provider API keys for the Inference Gateway. Set at least one; the gateway
# reads these from the environment (docker-compose.yml passes this file via
# env_file). See https://docs.inference-gateway.com for the full provider list.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=

# Note: PostgreSQL credentials for this example are set directly in
# docker-compose.yml (infer/infer) and .infer/config.yaml. For a real
# deployment, move the password out of config into
# INFER_STORAGE_POSTGRES_PASSWORD instead.
